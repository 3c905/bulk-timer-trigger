<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>org.jenkins-ci.plugins</groupId>
        <artifactId>plugin</artifactId>
        <version>5.4</version>
        <relativePath/>
    </parent>

    <groupId>com.medsci.jenkins</groupId>
    <artifactId>bulk-timer-trigger</artifactId>
    <version>1.0.0</version>
    <packaging>hpi</packaging>

    <name>Bulk Timer Trigger</name>

    <properties>
        <!-- Jenkins 2.479+ 已完成 Jakarta EE 迁移，parent POM 5.x 要求 JDK 17+ -->
        <jenkins.version>2.555.2</jenkins.version>
        <!-- Jenkins 2.555.2 最低支持 Java 17；设为 17 可同时兼容 Java 17/21 运行环境 -->
        <maven.compiler.release>17</maven.compiler.release>
        <!-- 跳过 Spotless 代码格式化检查，避免构建失败（如需启用可删除此行） -->
        <spotless.check.skip>true</spotless.check.skip>
        <!-- 覆盖 parent POM 中旧版 hpi-plugin，使用支持 Java 21 的最新版本 -->
        <hpi-plugin.version>3.1814.v77d15159f9b_d</hpi-plugin.version>
    </properties>

    <repositories>
        <repository>
            <id>repo.jenkins-ci.org</id>
            <url>https://repo.jenkins-ci.org/public/</url>
        </repository>
    </repositories>

    <pluginRepositories>
        <pluginRepository>
            <id>repo.jenkins-ci.org</id>
            <url>https://repo.jenkins-ci.org/public/</url>
        </pluginRepository>
    </pluginRepositories>
</project>
